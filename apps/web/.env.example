# Cycle Sentinel frontend (apps/web). Copy to .env.local to override. All vars are build-time (VITE_).

# Data source. Default (unset) = the REAL backend via the Vite /api proxy.
# Set true for offline, mock-only frontend dev (no backend needed).
# VITE_USE_MOCKS=true

# Where the Vite dev proxy forwards /api. Default: http://localhost:8000 (the FastAPI backend).
# VITE_API_TARGET=http://localhost:8000
