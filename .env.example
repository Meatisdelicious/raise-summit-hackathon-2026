# Cycle Sentinel environment. Copy to .env and fill for LIVE mode. NEVER commit a filled .env.

# --- Inference mode: live | replay | stub  (tests use replay; the demo uses live) ---
CS_INFERENCE_MODE=replay

# --- Vultr Serverless Inference (OpenAI-compatible) ---
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1
# Ids confirmed against `GET /v1/models` (Authorization: Bearer $VULTR_INFERENCE_API_KEY).
CS_LLM_MODEL=moonshotai/Kimi-K2.6                           # Kimi K2 (text-only reasoning/tool LLM)
CS_RETRIEVER_MODEL=vultr/VultronRetrieverPrime-Qwen3.5-8B   # Vultron Prime-8B — a ReRank model (optional)

# --- Protocol/SOP corpus store (Vultr Vector Store, EU — HDS-aligned) ---
# One collection PER rule_type; VULTR_VECTOR_COLLECTION is a short prefix (ids: cs+ohss -> "csohss",
# cs+lut, cs+poor, cs+stim). Build them with: `python scripts/index_corpus.py`.
VECTOR_STORE=vultr        # vultr (Vultr Vector Store, EU) | pgvector (fallback) | local (offline dev)
VULTR_VECTOR_COLLECTION=cs
DATABASE_URL=postgresql+psycopg://cyclesentinel:cyclesentinel@localhost:5432/cyclesentinel  # app data (+ pgvector fallback)
VULTR_REGION=eu   # keep protocol/SOP + hormone data + inference in an EU region

# --- Vultr Object Storage (synthetic protocol/SOP source docs; private bucket only) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- App ---
APP_SECRET_KEY=
LOG_LEVEL=INFO
