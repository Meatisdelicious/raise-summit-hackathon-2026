# Cycle Sentinel environment. Copy to .env and fill for LIVE mode. NEVER commit a filled .env.

# --- Inference mode: live | replay | stub  (tests use replay; the demo uses live) ---
CS_INFERENCE_MODE=replay

# --- Vultr Serverless Inference (planning, interpretation-in-context, brief generation) ---
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_BASE_URL=
VULTR_MODEL=

# --- Protocol/SOP vector store (Vultr-hosted, EU region — HDS-aligned sovereignty) ---
# Option A: Vultr Managed PostgreSQL + pgvector (EU region)
DATABASE_URL=postgresql+psycopg://cyclesentinel:cyclesentinel@localhost:5432/cyclesentinel
VECTOR_STORE=pgvector
VULTR_REGION=eu   # keep protocol/SOP + hormone data in an EU region

# --- Vultr Object Storage (synthetic protocol/SOP source docs; private bucket only) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- App ---
APP_SECRET_KEY=
LOG_LEVEL=INFO
