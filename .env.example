# LoopCloser environment (see docs/doc.md §8.4). Copy to .env and fill for LIVE mode.
# NEVER commit a filled .env. NEVER put a real value in this example file.

# --- Inference mode: live | replay | stub  (CI/tests use replay; the demo uses live) ---
LOOPCLOSER_INFERENCE_MODE=replay

# --- Vultr Serverless Inference (required for live mode / the demo) ---
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_BASE_URL=
VULTR_MODEL=

# --- Database (Vultr Managed PostgreSQL in prod; local Postgres for dev/CI) ---
DATABASE_URL=postgresql+psycopg://loopcloser:loopcloser@localhost:5432/loopcloser

# --- Vultr Object Storage (S3-compatible; private bucket only) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- App ---
APP_SECRET_KEY=
LOG_LEVEL=INFO
